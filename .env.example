# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-example-123456.eu-central-1.aws.neon.tech/pitopitu?sslmode=require"

# NextAuth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_RESEND_KEY="re_xxxxxxxxxxxx"

# For magic link emails without Resend (development only)
# AUTH_EMAIL_SERVER="smtp://user:pass@smtp.ethereal.email:587"

# App URL (used for emails/links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (transactional email for reminders)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Vercel Cron (for reminder system)
CRON_SECRET="your-cron-secret-here"

# Sender email for notifications
EMAIL_FROM="noreply@pitopitu.it"